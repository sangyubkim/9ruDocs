{
  "expo": {
    "name": "9ruDocs",
    "slug": "9rudocs",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nineru.docs",
      "infoPlist": {
        "NSCameraUsageDescription": "단계별 사진을 촬영합니다.",
        "NSPhotoLibraryUsageDescription": "갤러리에서 사진을 선택하고 촬영 사진을 저장합니다.",
        "NSPhotoLibraryAddUsageDescription": "카메라로 촬영한 사진을 갤러리에 저장합니다.",
        "NSLocationWhenInUseUsageDescription": "단계별 현재 위치를 기록합니다.",
        "NSMicrophoneUsageDescription": "음성으로 글 내용을 입력합니다.",
        "NSSpeechRecognitionUsageDescription": "음성을 텍스트로 변환합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.nineru.docs",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "갤러리에서 단계 사진을 선택합니다.",
          "cameraPermission": "카메라로 단계 사진을 촬영합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "촬영한 사진을 갤러리에 저장합니다.",
          "savePhotosPermission": "촬영한 사진을 갤러리에 저장합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "단계별 현재 위치를 기록합니다."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4052435f-32ed-468f-9dd1-94d72dbaacf3"
      }
    }
  }
}
